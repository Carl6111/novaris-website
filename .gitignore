# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db

# secrets & certificates
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt
id_rsa
id_ed25519
secrets.json
credentials.json
tokens.json
service-account.json
*.secret.*

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local scratch / heavy source media (not used by build)
/*.mp4
/robot eye*.jpg
/novarisoriginal.png
/_*.mjs
_shoot*.mjs
